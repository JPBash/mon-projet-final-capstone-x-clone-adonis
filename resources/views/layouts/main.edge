<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clone X - {{ title || 'Accueil' }}</title>
    <link rel="stylesheet" href="/styles.css" />
</head>
<body>

    {{-- HEADER MOBILE (visible uniquement sur mobile) --}}
    <header class="mobile-header">
        @if(auth.user)
          <div class="avatar" style="width:32px;height:32px;">
          </div>
        @else
          <a href="{{ route('auth.login.show') }}" style="font-weight:700;">Connexion</a>
        @endif

        {{-- Logo X centré --}}
        <span style="font-size:22px; font-weight:800; position:absolute; left:50%; transform:translateX(-50%);">X</span>

        {{-- Bouton recherche --}}
        <a href="{{ route('tweets.search') }}" class="nav-icon-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </a>
    </header>

    <div class="layout">
        {{-- SIDEBAR (desktop) --}}
        <aside class="sidebar">
            <div class="brand">X</div>
            <nav class="nav-menu">
                <a href="{{ route('home') }}" class="nav-link">Accueil</a>
                <a href="#" class="nav-link">Grok</a>
                <a href="#" class="nav-link">Profil</a>
            </nav>
            
            @if(auth.user)
              <div class="user-chip">
                <div class="avatar"></div>
                <div>
                  <p>{{ auth.user.fullName }}</p>
                  <p class="muted">{{ auth.user.email }}</p>
                </div>
              </div>
              <form action="{{ route('auth.logout') }}" method="POST">
                {{ csrfField() }}
                <button type="submit" class="btn btn-outline">Se déconnecter</button>
              </form>
            @endif
        </aside>

        {{-- CONTENU DYNAMIQUE --}}
        <section class="feed-panel">
            {{{ await $slots.main() }}}
        </section>

        {{-- RIGHT PANEL (desktop) --}}
        <aside class="right-panel">
            <form action="{{ route('tweets.search') }}" method="GET" class="search-box">
                <input type="text" name="q" placeholder="Chercher" value="{{ query || '' }}" />
            </form>
            <div class="card"><h3>Ce qui se passe</h3></div>
        </aside>
    </div>

    {{-- BARRE DE NAVIGATION BASSE (mobile uniquement) --}}
    <nav class="bottom-nav">
        <a href="{{ route('home') }}" class="nav-icon-link" title="Accueil">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
        </a>
        <a href="{{ route('tweets.search') }}" class="nav-icon-link" title="Recherche">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </a>
        <a href="#" class="nav-icon-link" title="Profil">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
        </a>
    </nav>

    {{-- FAB : Bouton flottant pour composer un tweet (mobile uniquement) --}}
    @if(auth.user)
    <a href="{{ route('home') }}#composer" class="fab" title="Tweeter">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
    </a>
    @endif

</body>
</html>

  <body>
    <main id="app" class="app-shell"></main>

      <section class="welcome-layout">
        <div class="welcome-logo-wrap">
          <div class="x-mark" aria-hidden="true">X</div>
        </div>
        <div class="welcome-panel">
          <h1>Ca se passe maintenant</h1>
          <h2>Inscrivez-vous.</h2>
          <button id="open-signup" class="btn btn-primary">Creer un compte</button>
          <div class="divider"><span>ou</span></div>
          <p class="helper-text">Vous avez deja un compte ?</p>
          <button id="open-login" class="btn btn-outline">Se connecter</button>
        </div>
      </section>
  
    <dialog id="auth-dialog" class="auth-dialog">
      <form method="dialog" class="auth-card" id="auth-form">
        <button type="button" class="dialog-close" id="close-auth">x</button>
        <h2 id="auth-title">Se connecter</h2>
        <div id="signup-only" class="hidden">
          <input name="name" placeholder="Nom et prenom" />
          <input name="username" placeholder="Pseudo" />
        </div>
        <input type="email" name="email" placeholder="Email" required />
        <input type="password" name="password" placeholder="Mot de passe" required />
        <button type="submit" class="btn btn-primary btn-wide" id="auth-submit">Continuer</button>
        <p class="muted" id="auth-switch-line"></p>
      </form>
    </dialog>

    @if(auth.user)
     <form action="{{ route('tweets.store') }}" method="POST" class="tweet-box">

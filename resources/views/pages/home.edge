<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clone X - Accueil</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
</head>
<body>
    <main id="app" class="app-shell">
        
        @if(auth.user)
          <div class="layout">
            {{-- Sidebar --}}
            <aside class="sidebar">
              <div class="brand">X</div>
              <nav class="nav-menu">
                <a href="{{ route('home') }}" class="nav-link active">Accueil</a>
                <button class="nav-link">Explorer</button>
                <button class="nav-link">Notifications</button>
                <button class="nav-link">Messages</button>
                <button class="nav-link">Paramètres</button>
                <a href="{{ route('profile.show') }}" class="nav-link">Profil</a>
              </nav>

              {{-- SECTION USER CHIP --}}
              <div class="user-chip">
                <div class="avatar">
                  @if(auth.user.avatarUrl)
                    <img src="{{ auth.user.avatarUrl }}" alt="Avatar">
                  @else
                    <div class="avatar-placeholder">{{ auth.user.fullName.charAt(0) }}</div>
                  @endif
                </div>
                <div>
                  <p><strong>{{ auth.user.fullName }}</strong></p>
                  <p class="muted">{{ auth.user.email }}</p>
                </div>
              </div>

              <form action="{{ route('auth.logout') }}" method="POST">
                {{ csrfField() }}
                <button type="submit" class="btn btn-outline" style="width: 100%; margin-top: 10px;">Se déconnecter</button>
              </form>
            </aside>

            {{-- Flux Principal --}}
            <section class="feed-panel">
              <header class="feed-header">
                <h2>Accueil</h2>
                <div class="tabs">
                  <a href="{{ route('home') }}?tab=all" 
                     class="tab {{ currentTab === 'all' || !currentTab ? 'active' : '' }}">
                     Pour vous
                  </a>
                  <a href="{{ route('home') }}?tab=following" 
                     class="tab {{ currentTab === 'following' ? 'active' : '' }}">
                     Abonnements
                  </a>
                </div>
              </header>

              {{-- Boîte de publication --}}
               <form action="{{ route('tweets.store') }}" method="POST" class="tweet-box">
                 {{ csrfField() }}
                 <div class="avatar">
                    @if(auth.user.avatarUrl)
                      <img src="{{ auth.user.avatarUrl }}" alt="Mon Avatar">
                    @else
                      <div class="avatar-placeholder">{{ auth.user.fullName.charAt(0) }}</div>
                    @endif
                 </div>
                 <div class="tweet-input-wrap">
                    <textarea name="content" maxlength="280" placeholder="Quoi de neuf ?" required></textarea>
                    <div class="tweet-actions">
                      <button type="submit" class="btn btn-primary">Poster</button>
                    </div>
                 </div>
               </form>

              {{-- Liste des Tweets --}}
              <div id="feed-list" class="tweet-list">
                @each(tweet in tweets)
                  <div class="tweet">
                    <div class="avatar">
                      @if(tweet.user.avatarUrl)
                        <img src="{{ tweet.user.avatarUrl }}" alt="Avatar de {{ tweet.user.fullName }}">
                      @else
                        <div class="avatar-placeholder">{{ tweet.user.fullName.charAt(0) }}</div>
                      @endif
                    </div>

                    <div class="tweet-content">
                      <div style="display: flex; justify-content: space-between;">
                        <div>
                          <strong>{{ tweet.user.fullName }}</strong>
                          <span class="muted">{{ tweet.user.email }}</span>
                        </div>

                        @if(tweet.userId === auth.user.id)
                          <form action="{{ route('tweets.destroy', { id: tweet.id }) }}?_method=DELETE" method="POST">
                            {{ csrfField() }}
                            <button type="submit" class="tweet-action tweet-action-delete" onclick="return confirm('Supprimer ce tweet ?')">
                                Supprimer
                            </button>
                          </form>
                        @endif
                      </div>

                      <p>{{ tweet.content }}</p>

                      <div class="tweet-footer">
                        <form action="{{ route('tweets.like', { id: tweet.id }) }}" method="POST">
                          {{ csrfField() }}
                          <button type="submit" class="tweet-action tweet-action-like" style="color: {{ (tweet.likes && tweet.likes.some(l => l.userId === auth.user.id)) ? '#f91880' : '' }}">
                            @if(tweet.likes && tweet.likes.some(l => l.userId === auth.user.id))
                              ❤️
                            @else
                              🤍
                            @endif
                            <span>{{ tweet.$extras.likes_count || 0 }}</span>
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                @else
                  <div style="padding: 40px; text-align: center; color: #71767b;">
                    <p>Aucun tweet à afficher pour le moment.</p>
                  </div>
                @endeach
              </div>
            </section>

            {{-- Panel Droit --}}
            <aside class="right-panel">
              <div class="search-box">
                <input type="text" placeholder="Chercher" />
              </div>
              <section class="card">
                <h3>Ce qui se passe</h3>
                <ul class="simple-list">
                  <li>#AdonisJS</li>
                  <li>#KadeaAcademy</li>
                  <li>#Actu Est de la RDC</li>
                </ul>
              </section>
            </aside>
          </div>
        @endif

    </main>
</body>
</html>
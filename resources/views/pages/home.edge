<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clone X - Accueil</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
</head>
<body>
    <main id="app" class="app-shell">
        
        @if(auth.user)
          <div class="layout">
            <aside class="sidebar">
              <div class="brand">X</div>
              <nav class="nav-menu">
                <button class="nav-link active">Accueil</button>
                <button class="nav-link">Explorer</button>
                <button class="nav-link">Notifications</button>
                <button class="nav-link">Messages</button>
                <button class="nav-link">Profil</button>
              </nav>

              <div class="user-chip">
                {{-- On remplace les id vides par les vraies données Adonis --}}
                <div class="avatar">{{ auth.user.fullName.charAt(0) }}</div>
                <div>
                  <p><strong>{{ auth.user.fullName }}</strong></p>
                  <p class="muted">{{ auth.user.email }}</p>
                </div>
              </div>

              {{-- Formulaire de déconnexion (obligatoire pour que le bouton fonctionne) --}}
              <form action="{{ route('auth.logout') }}" method="POST">
                {{ csrfField() }}
                <button type="submit" class="btn btn-outline" style="width: 100%; margin-top: 10px;">Se deconnecter</button>
              </form>
            </aside>

            <section class="feed-panel">
              <header class="feed-header">
                <div class="tabs">
                  <button class="tab active">Pour vous</button>
                  <button class="tab">Abonnements</button>
                </div>
              </header>

              {{-- IMPORTANT : On enlève la classe "hidden" et on ajoute action/method --}}
              <form action="{{ route('tweets.store') }}" method="POST" class="tweet-box">
                {{ csrfField() }}
                <div class="avatar">{{ auth.user.fullName.charAt(0) }}</div>
                <div class="tweet-input-wrap">
                  <textarea
                    name="content"
                    maxlength="280"
                    placeholder="Quoi de neuf ?"
                    required
                  ></textarea>
                  <div class="tweet-actions">
                    <button type="submit" class="btn btn-primary">Poster</button>
                  </div>
                </div>
              </form>

              <div id="feed-list" class="tweet-list">
                @each(tweet in tweets)
                  <div class="tweet" style="padding: 1rem; border-bottom: 1px solid #333; display: flex; gap: 1rem;">
                    <div class="avatar">{{ tweet.user.fullName.charAt(0) }}</div>
                    <div>
                      <strong>{{ tweet.user.fullName }}</strong>
                      <p>{{ tweet.content }}</p>
                    </div>
                  </div>
                @endeach
              </div>
            </section>

            <aside class="right-panel">
              <div class="search-box">
                <input type="text" placeholder="Chercher" />
              </div>
              <section class="card">
                <h3>Ce qui se passe</h3>
                <ul class="simple-list">
                  <li>#AdonisJS</li>
                  <li>#KadeaAcademy</li>
                  <li>#Actu Est de la RDC</li>
                </ul>
              </section>
            </aside>
          </div>
        @endif

    </main>
</body>
</html>
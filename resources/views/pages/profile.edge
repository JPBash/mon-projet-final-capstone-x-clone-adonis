        </a>
    </nav>

    {{-- Bouton flottant pour tweeter --}}
    <a href="{{ route('home') }}#composer" class="fab" title="Tweeter">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
    </a>
    @endif

</body>
</html>

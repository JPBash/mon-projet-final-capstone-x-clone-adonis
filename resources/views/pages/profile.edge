        </a>
        <a href="{{ route('tweets.search') }}" class="nav-icon-link" title="Recherche">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </a>
        <a href="{{ route('profile.show') }}" class="nav-icon-link" title="Profil">
